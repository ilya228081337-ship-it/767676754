{
  "manifest_version": 3,
  "name": "TextLens - Image OCR",
  "version": "1.0.0",
  "description": "Extract text from images using OCR. Supports JPG, JPEG, PNG, and WebP formats.",
  "permissions": ["sidePanel"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open TextLens"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["worker.min.js", "tesseract-core.wasm.js", "lang/*.traineddata", "lang/*.traineddata.gz"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; worker-src 'self';"
  }
}
